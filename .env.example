# Copy this file to .env and fill in your values.
# .env is gitignored — it will never be committed.
# Get a free key at https://aistudio.google.com/apikey

GEMINI_API_KEY=AIza...

# APP_ENV controls model selection:
#   dev  (default) — gemini-2.5-flash-lite router + gemini-2.5-flash expert; cheap iteration
#   demo           — gemini-2.5-flash for router, gemini-2.5-pro for expert; best quality
# Override individual models with ROUTER_MODEL / EXPERT_MODEL if needed.
APP_ENV=dev

# RATE_LIMIT_INTERVAL=13.0  # free tier (5 RPM) — uncomment if you hit 429s
RATE_LIMIT_INTERVAL=1.0     # paid tier (~1000 RPM)
