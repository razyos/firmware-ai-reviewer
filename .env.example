# Copy this file to .env and fill in your values.
# .env is gitignored — it will never be committed.
# Get a free key at https://aistudio.google.com/apikey

GEMINI_API_KEY=AIza...

# Optional: override models (defaults shown)
# Free tier:    EXPERT_MODEL=gemini-2.5-flash
# Requires billing enabled on Google Cloud project:
# EXPERT_MODEL=gemini-3.1-pro-preview
ROUTER_MODEL=gemini-2.5-flash
EXPERT_MODEL=gemini-2.5-flash
# RATE_LIMIT_INTERVAL=13.0  # free tier (5 RPM) — uncomment if you hit 429s
RATE_LIMIT_INTERVAL=1.0     # paid tier (~1000 RPM)
